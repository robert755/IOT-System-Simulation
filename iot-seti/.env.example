# ====================================================================
#  Example environment configuration.
#  Copy this file to ".env" and fill in your own values:
#      cp .env.example .env        (Linux/macOS)
#      copy .env.example .env      (Windows)
#  The real ".env" file is git-ignored and never committed.
# ====================================================================

# --- MongoDB ---
# Local:  mongodb://localhost:27017/
# Atlas:  mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=Cluster0
MONGO_URI=mongodb://localhost:27017/
MONGO_DB=seti_iot

# --- MQTT broker ---
MQTT_SERVER=broker.hivemq.com
MQTT_PORT=1883
MQTT_USER=
MQTT_PASS=
MQTT_CLIENT=python-backend-001
# IMPORTANT: change PREFIX to something unique so your data does not
# mix with other users on the public broker (e.g. seti2025/your_name)
PREFIX=seti2025/grupaX

# --- E-mail alerting (optional) ---
# For Gmail: enable 2FA and generate an "App Password".
# Set ENABLE_EMAIL=False to run without e-mail alerts.
ENABLE_EMAIL=False
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_TO=destination@gmail.com
EMAIL_COOLDOWN=10
